# Google Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Postgres connection string. Use the pooled URL when deploying to Vercel/Neon.
# Local docker-compose maps Postgres to host port 5433 (5432 left free for other stacks).
# Default compose dev credentials are user/password "spur"/"spur" — override via POSTGRES_USER/POSTGRES_PASSWORD.
DATABASE_URL="postgresql://<user>:<password>@localhost:5433/spur_chat?schema=public"
